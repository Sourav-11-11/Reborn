# MongoDB Atlas Connection (copy full connection string)
ATLAS_URL=mongodb+srv://username:password@cluster.mongodb.net/reborn?retryWrites=true&w=majority
# OR Local MongoDB
MONGO_URL=mongodb://localhost:27017/reborn

# Server Configuration
PORT=8000

# Session Secret (use a strong random string in production)
SECRET_KEY=your_session_secret_key_here_change_this_in_production

# Cloudinary Configuration
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret
