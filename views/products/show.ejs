<% layout("/layouts/boilerplate") %>

<div class="max-w-[1200px] mx-auto px-6 pt-8 pb-16 lg:px-8 min-h-[70vh]">
  
  <div class="mb-8 flex items-center justify-between">
    <h3 class="text-2xl font-black tracking-tight text-on-surface">Product Details</h3>
    <% if (product.sold) { %>
      <span class="bg-error text-white text-xs font-bold px-4 py-1.5 rounded-full tracking-widest uppercase">Sold</span>
    <% } %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
    <!-- Image Column -->
    <div class="rounded-[2rem] overflow-hidden bg-surface-container-low aspect-[4/5] shadow-sm border border-outline-variant/10">
      <img src="<%= product.image %>" class="w-full h-full object-cover" alt="<%= product.productName %> image">
    </div>

    <!-- Details Column -->
    <div class="flex flex-col gap-8 lg:pt-8">
      
      <div>
        <h1 class="text-3xl md:text-4xl font-black editorial-display text-on-surface mb-2"><%= product.productName %></h1>
        <div class="flex items-center gap-3">
            <p class="text-[12px] font-bold uppercase tracking-widest text-on-surface-variant"><%= product.category %></p>
            <span class="text-outline-variant">•</span>
            <span class="bg-tertiary-container/20 text-tertiary text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest"><%= product.condition %></span>
        </div>
      </div>

      <div class="bg-surface-container-low p-6 rounded-2xl">
        <p class="text-on-surface-variant leading-relaxed"><%= product.description %></p>
      </div>

      <div class="flex items-center gap-4 border-b border-outline-variant/20 pb-8">
        <p class="text-xs text-on-surface uppercase tracking-widest font-bold">Price</p>
        <p class="text-3xl font-black text-tertiary">₹ <%= product.price.toLocaleString("en-IN") %></p>
      </div>

      <div class="space-y-2 text-sm text-on-surface-variant">
        <p><strong>Seller:</strong> <span class="text-on-surface"><%= product.seller %></span></p>
        <p><strong>Listed:</strong> <%= product.createdAt.toLocaleDateString() %></p>
      </div>

      <!-- BUY / INTEREST SECTION -->
      <% if (!product.sold && !showSeller) { %>
        <div class="pt-4">
          <a href="/products/<%= product._id %>/interested" class="block w-full text-center px-8 py-4 bg-tertiary text-white rounded-xl font-bold shadow-lg shadow-tertiary/20 hover:-translate-y-1 transition-transform">
            Interested to Buy
          </a>
        </div>
      <% } %>

      <!-- SELLER DETAILS -->
      <% if (showSeller) { %>
        <div class="bg-tertiary-container/10 border border-tertiary/20 p-6 rounded-2xl mt-4">
          <h4 class="text-tertiary font-bold mb-4 uppercase tracking-widest text-xs flex items-center gap-2">
            <span class="material-symbols-outlined text-[16px]">contact_mail</span> Seller Details
          </h4>
          <div class="space-y-3 text-sm text-on-surface">
            <div class="grid grid-cols-[80px_1fr] gap-2"><span class="text-on-surface-variant">Name:</span> <strong><%= product.owner ? product.owner.username : product.seller %></strong></div>
            <div class="grid grid-cols-[80px_1fr] gap-2"><span class="text-on-surface-variant">Degree:</span> <strong><%= product.owner && product.owner.degree ? product.owner.degree : 'BTech' %></strong></div>
            <div class="grid grid-cols-[80px_1fr] gap-2"><span class="text-on-surface-variant">Phone:</span> <strong><%= product.contactNumber || 'Not Provided' %></strong></div>
            <div class="grid grid-cols-[80px_1fr] gap-2"><span class="text-on-surface-variant">Email:</span> <strong><%= product.owner ? product.owner.email : 'Not Provided' %></strong></div>
          </div>
        </div>
      <% } %>

      <!-- ADMIN ACTIONS -->
      <% if (currUser && product.owner && product.owner._id.equals(currUser._id)) { %>
      <div class="mt-12 pt-8 border-t border-outline-variant/20">
        <p class="text-[10px] font-bold uppercase tracking-[0.05em] text-outline mb-4">Admin Controls</p>
        <div class="flex flex-wrap gap-3">
          <a href="/products/<%= product._id %>/edit" class="px-5 py-2 border border-primary/30 text-primary rounded-lg text-sm font-bold hover:bg-primary/5 transition-colors">Edit</a>

          <form method="POST" action="/products/<%= product._id %>?_method=DELETE" class="inline">
            <button class="px-5 py-2 border border-error/30 text-error rounded-lg text-sm font-bold hover:bg-error/5 transition-colors">Delete</button>
          </form>

          <% if (product.sold) { %>
            <form method="POST" action="/products/<%= product._id %>/unsold?_method=PATCH" class="inline">
              <button class="px-5 py-2 border border-outline text-on-surface rounded-lg text-sm font-bold hover:bg-surface-variant transition-colors">Mark as Unsold</button>
            </form>
          <% } else { %>
            <form method="POST" action="/products/<%= product._id %>/buy?_method=PATCH" class="inline">
              <button class="px-5 py-2 bg-surface-container-highest text-on-surface rounded-lg text-sm font-bold hover:opacity-80 transition-opacity">Mark as Sold</button>
            </form>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
