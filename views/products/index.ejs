<% layout("/layouts/boilerplate") %>

<section class="max-w-[1440px] mx-auto px-6 pb-12 lg:px-8 min-h-[60vh]">
  <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-8">
    <div>
      <span class="text-[10px] font-bold uppercase tracking-[0.05em] text-tertiary">The Collection</span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight mt-2 text-on-surface">Second Life Store <i class="fa-solid fa-heart text-tertiary text-3xl ml-2"></i></h2>
    </div>
    <a class="text-tertiary font-bold flex items-center gap-2 hover:gap-4 transition-all group" href="/products/new">
        List an item <span class="material-symbols-outlined">add_circle</span>
    </a>
  </div>

  <% if (!allProducts || allProducts.length === 0) { %>
    <div class="bg-surface-container-low p-12 rounded-3xl text-center shadow-inner border border-outline-variant/10">
      <span class="material-symbols-outlined text-6xl text-outline mb-4">inventory_2</span>
      <h3 class="text-2xl font-bold text-on-surface mb-2">The store is empty</h3>
      <p class="text-on-surface-variant mb-6 text-balance">Be the first to give your stuff a second life and list an item for the community.</p>
      <a href="/products/new" class="inline-block px-8 py-4 bg-tertiary text-white rounded-xl font-bold shadow-lg shadow-tertiary/20 hover:-translate-y-1 transition-transform">List an item</a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      <% for (let product of allProducts) { %>
        <div class="group cursor-pointer">
          <a href="/products/<%= product._id %>" class="block">
            <div class="rounded-[2rem] overflow-hidden bg-surface-container-low aspect-[4/5] relative mb-5 shadow-sm group-hover:shadow-[0_20px_40px_rgba(45,51,56,0.08)] transition-all duration-500 will-change-transform group-hover:-translate-y-2">
              <img src="<%= product.image %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="<%= product.productName %>">
              
              <% if (product.sold) { %>
                <div class="absolute inset-0 bg-inverse-surface/40 flex justify-center items-center z-10 backdrop-blur-[2px]">
                  <span class="bg-error text-white font-black tracking-widest px-6 py-2 rounded-lg -rotate-12 text-xl shadow-2xl border-2 border-white/20">SOLD</span>
                </div>
              <% } %>
              
              <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-4 py-1.5 rounded-full shadow-sm z-20">
                <span class="text-[10px] font-bold uppercase tracking-widest text-tertiary"><%= product.condition %></span>
              </div>
            </div>
            
            <div class="flex justify-between items-start px-2">
              <div>
                <h4 class="font-bold text-base md:text-lg text-on-surface group-hover:text-tertiary transition-colors line-clamp-1"><%= product.productName %></h4>
                <p class="text-[9px] md:text-[10px] text-on-surface-variant uppercase tracking-widest font-medium mt-1"><%= product.category %></p>
              </div>
              <div class="font-bold text-tertiary text-base md:text-lg ml-2 shrink-0">₹ <%= product.price.toLocaleString("en-IN") %></div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
    
    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <div class="mt-12 md:mt-16 flex justify-center items-center gap-2 md:gap-4">
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>&limit=<%= limit %>" class="px-3 md:px-4 py-2 bg-surface-container-high hover:bg-tertiary hover:text-white rounded-lg transition-colors flex items-center justify-center shadow-sm text-sm">
            <span class="material-symbols-outlined text-[18px]">chevron_left</span>
          </a>
        <% } %>

        <div class="flex items-center gap-1 md:gap-2">
          <% for(let i=1; i<=totalPages; i++) { %>
            <a href="?page=<%= i %>&limit=<%= limit %>" class="w-8 h-8 md:w-10 md:h-10 flex items-center justify-center rounded-lg font-bold text-sm transition-all <%= currentPage === i ? 'bg-tertiary text-white shadow-md shadow-tertiary/30' : 'bg-surface-container hover:bg-surface-container-highest text-on-surface-variant' %>">
              <%= i %>
            </a>
          <% } %>
        </div>

        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>&limit=<%= limit %>" class="px-3 md:px-4 py-2 bg-surface-container-high hover:bg-tertiary hover:text-white rounded-lg transition-colors flex items-center justify-center shadow-sm text-sm">
            <span class="material-symbols-outlined text-[18px]">chevron_right</span>
          </a>
        <% } %>
      </div>
    <% } %>
  <% } %>
</section>
