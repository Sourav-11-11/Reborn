<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Edit Product</h3>
    <form method="POST" action="/products/<%= product._id %>?_method=PUT" novalidate class="needs-validation">
      
      <div class="mb-3">
        <label for="productName" class="form-label">Product Name:</label>
        <input 
            name="product[productName]" 
            value="<%= product.productName %>" 
            placeholder="e.g., Vintage Leather Jacket" 
            type="text" 
            class="form-control" 
            required
        />
        <div class="valid-feedback">Product name looks good!</div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-6">
          <label for="category" class="form-label">Category:</label>
          <select 
            name="product[category]" 
            class="form-control" 
            required
          >
            <option value="<%= product.category %>" selected><%= product.category %></option>
            <option value="Clothing">Clothing</option>
            <option value="Footwear">Footwear</option>
            <option value="Accessories">Accessories</option>
            <option value="Home">Home & Decor</option>
            <option value="Electronics">Electronics</option>
            <option value="Books">Books</option>
            <option value="Other">Other</option>
          </select>
          <div class="invalid-feedback">Please select a category.</div>
        </div>

        <div class="mb-3 col-md-6">
          <label for="condition" class="form-label">Condition:</label>
          <select 
            name="product[condition]" 
            class="form-control" 
            required
          >
            <option value="<%= product.condition %>" selected><%= product.condition %></option>
            <option value="New">New</option>
            <option value="Like New">Like New</option>
            <option value="Used">Used</option>
          </select>
          <div class="invalid-feedback">Please select the condition.</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description:</label>
        <textarea 
            name="product[description]" 
            placeholder="Describe the product condition, size, brand, etc." 
            class="form-control" 
            rows="4" 
            cols="50" 
            required
        ><%= product.description %></textarea>
        <div class="invalid-feedback">Please enter a description.</div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Image URL:</label>
        <input 
            name="product[image]" 
            value="<%= product.image %>" 
            type="text" 
            class="form-control"
        />
      </div>

      <div class="mb-3">
        <label for="price" class="form-label">Price (₹):</label>
        <input 
          name="product[price]" 
          value="<%= product.price %>" 
          placeholder="Enter price" 
          type="number" 
          step="0.01"
          class="form-control" 
          required
        />
        <div class="invalid-feedback">Price should be valid</div>
      </div>

      <div class="mb-3">
        <label for="seller" class="form-label">Seller Name:</label>
        <input 
          name="product[seller]" 
          value="<%= product.seller %>" 
          placeholder="Your name" 
          type="text" 
          class="form-control"
        />
      </div>

      <div class="mb-3">
        <label for="isSold" class="form-label">
          <input 
            type="checkbox" 
            name="product[isSold]" 
            value="on"
            <% if (product.isSold) { %> checked <% } %>
          />
          Mark as Sold
        </label>
      </div>

      <button class="btn btn-dark edit-btn mt-3">Update Product</button>
    </form>
  </div>  
</div>

<script>
  // Bootstrap form validation
  (function() {
    'use strict';
    window.addEventListener('load', function() {
      let forms = document.querySelectorAll('.needs-validation');
      Array.prototype.slice.call(forms).forEach(function(form) {
        form.addEventListener('submit', function(event) {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    }, false);
  })();
</script>
