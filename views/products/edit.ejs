<% layout("/layouts/boilerplate") %>

<div class="max-w-[800px] mx-auto px-6 pt-8 pb-20 min-h-[70vh]">
  
  <div class="text-center mb-12">
    <span class="inline-flex items-center gap-2 px-4 py-2 bg-primary-container/30 text-primary rounded-full mb-6">
      <span class="material-symbols-outlined text-[18px]">edit</span>
      <span class="text-[10px] font-bold uppercase tracking-[0.05em]">Update Listing</span>
    </span>
    <h3 class="text-4xl font-black editorial-display tracking-tight text-on-surface">Edit Product</h3>
  </div>

  <div class="bg-surface-container-low p-10 md:p-16 rounded-[2rem] shadow-sm border border-outline-variant/10">
    <form method="POST" action="/products/<%= product._id %>?_method=PUT" enctype="multipart/form-data" novalidate class="flex flex-col gap-6 needs-validation">
      
      <div class="flex flex-col gap-3">
        <label for="productName" class="text-sm font-bold text-on-surface ml-1">Product Name</label>
        <input name="product[productName]" value="<%= product.productName %>" placeholder="e.g., Vintage Leather Jacket" type="text" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant" required />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label for="category" class="text-sm font-bold text-on-surface ml-1">Category</label>
          <select name="product[category]" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none appearance-none cursor-pointer" required>
            <option value="<%= product.category %>" selected><%= product.category %></option>
            <option value="Clothing">Clothing</option>
            <option value="Footwear">Footwear</option>
            <option value="Accessories">Accessories</option>
            <option value="Home">Home & Decor</option>
            <option value="Electronics">Electronics</option>
            <option value="Books">Books</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label for="condition" class="text-sm font-bold text-on-surface ml-1">Condition</label>
          <select name="product[condition]" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none appearance-none cursor-pointer" required>
            <option value="<%= product.condition %>" selected><%= product.condition %></option>
            <option value="New">New</option>
            <option value="Like New">Like New</option>
            <option value="Used">Used</option>
          </select>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="description" class="text-sm font-bold text-on-surface ml-1">Description</label>
        <textarea name="product[description]" placeholder="Describe the product condition, size, brand, etc." rows="4" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant resize-none" required><%= product.description %></textarea>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold text-on-surface ml-1">Product Image</label>
        <% if (product.image) { %>
          <div class="bg-surface rounded-2xl p-4 border border-outline-variant/10 mb-4">
            <img src="<%= product.image %>" alt="Current image" class="w-full h-48 object-cover rounded-xl mb-2" />
            <p class="text-xs text-on-surface-variant">Current image - Upload a new one to replace it</p>
          </div>
        <% } %>
        <input name="product[image]" type="file" accept="image/*" class="w-full bg-surface py-4 px-6 rounded-2xl border-2 border-dashed border-outline-variant/50 hover:border-tertiary/50 focus:outline-none focus:ring-2 focus:ring-tertiary/50 transition-all file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-tertiary/10 file:text-tertiary hover:file:bg-tertiary/20 cursor-pointer" />
        <p class="text-xs text-on-surface-variant mt-2">Select an image from your device (JPEG, PNG, GIF, WebP - Max 5MB)</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label for="price" class="text-sm font-bold text-on-surface ml-1">Price (₹)</label>
          <input name="product[price]" value="<%= product.price %>" placeholder="Enter price" type="number" step="0.01" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant" required />
        </div>

        <div class="flex flex-col gap-2">
          <label for="seller" class="text-sm font-bold text-on-surface ml-1">Seller Name</label>
          <input name="product[seller]" value="<%= product.seller %>" placeholder="Your name" type="text" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant" />
        </div>
      </div>

      <div class="flex items-center gap-3 ml-2 mt-2">
        <input type="checkbox" name="product[isSold]" id="isSold" value="on" class="w-5 h-5 rounded bg-surface border border-outline-variant text-tertiary focus:ring-tertiary/50 cursor-pointer" <% if (product.isSold) { %> checked <% } %> />
        <label for="isSold" class="text-sm font-bold text-on-surface cursor-pointer select-none">Mark as Sold immediately</label>
      </div>

      <div class="pt-6 mt-6 border-t border-outline-variant/10">
        <button type="submit" class="w-full md:w-auto px-10 py-4 bg-tertiary text-white rounded-xl font-bold shadow-lg shadow-tertiary/20 hover:-translate-y-1 transition-transform">Update Product</button>
      </div>
    </form>
  </div>
</div>

<script>
  const form = document.querySelector('.needs-validation');
  if(form) {
    form.addEventListener('submit', function(event) {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    }, false);
  }
</script>
