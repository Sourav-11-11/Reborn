<% layout("/layouts/boilerplate") %>
<br>
<h3 class="fw-bold text-center mb-4">
  Help the Needy <i class="fa-solid fa-hand-holding-heart" style="color: #dc3545 !important; font-size: 2rem; margin-left: 0.5rem; display: inline-block;"></i>
</h3>
<p class="text-center text-muted mb-4">Donate your clothes and help those in need!</p>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Add a Donation</h3><br/>
    <form method="POST" action="/donate" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="productName" class="form-label">Item Name:</label>
        <input 
            name="product[productName]" 
            placeholder="e.g., Winter Jacket, T-Shirt, Jeans" 
            type="text"
            class="form-control"
            required 
        />
        <div class="valid-feedback">Item name looks good!</div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-6">
          <label for="category" class="form-label">Category:</label>
          <select 
            name="product[category]" 
            class="form-control" 
            required
          >
            <option value="">Select a category</option>
            <option value="Clothing">Clothing</option>
            <option value="Footwear">Footwear</option>
            <option value="Accessories">Accessories</option>
            <option value="Home">Home & Decor</option>
            <option value="Electronics">Electronics</option>
            <option value="Books">Books</option>
            <option value="Other">Other</option>
          </select>
          <div class="invalid-feedback">Please select a category.</div>
        </div>

        <div class="mb-3 col-md-6">
          <label for="condition" class="form-label">Condition:</label>
          <select 
            name="product[condition]" 
            class="form-control" 
            required
          >
            <option value="">Select condition</option>
            <option value="New">New</option>
            <option value="Like New">Like New</option>
            <option value="Used">Used</option>
          </select>
          <div class="invalid-feedback">Please select the condition.</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description:</label>
        <textarea
          name="product[description]"
          placeholder="Describe your donation (size, material, any special details, etc.)"
          rows="4"
          cols="50"
          class="form-control"
          required
        ></textarea>
        <div class="valid-feedback">Description looks good!</div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Image URL:</label>
        <input
          name="product[image]"
          placeholder="https://example.com/image.jpg"
          type="text"
          class="form-control"
        />
      </div>

      <div class="mb-3">
        <label for="donor" class="form-label">Your Name:</label>
        <input 
          name="product[seller]" 
          placeholder="Your name" 
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Name looks good!</div>
      </div>

      <div class="mb-3">
        <label for="contactNumber" class="form-label">Contact Number:</label>
        <input 
          name="product[contactNumber]" 
          placeholder="Your contact number" 
          type="tel"
          pattern="[0-9]{10}"
          class="form-control"
          required
        />
        <div class="valid-feedback">Contact number looks good!</div>
        <div class="invalid-feedback">Please enter a valid 10-digit contact number.</div>
      </div>

      <div class="mb-3">
        <button class="btn btn-success w-100">
          <i class="fa-solid fa-heart"></i> Make a Donation
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const forms = document.querySelectorAll('.needs-validation');
  Array.from(forms).forEach((form) => {
      form.addEventListener('submit', event => {
          if (!form.checkValidity()) {
              event.preventDefault();
              event.stopPropagation();
          }
          form.classList.add('was-validated');
      }, false)
  });
</script>
