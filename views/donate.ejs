<% layout("/layouts/boilerplate") %>

<div class="max-w-[800px] mx-auto px-6 pt-6 pb-24 min-h-[70vh]">
  <div class="text-center mb-10">
    <h3 class="text-3xl md:text-4xl font-black editorial-display tracking-tight text-on-surface flex items-center justify-center gap-3">
      Help the Needy <i class="fa-solid fa-hand-holding-heart text-error text-[2.5rem]"></i>
    </h3>
    <p class="text-on-surface-variant mt-4 text-lg">Donate your clothes and help those in need!</p>
  </div>

  <div class="bg-surface-container-low p-10 md:p-16 rounded-[2rem] shadow-sm border border-outline-variant/10 hover:shadow-md transition-all">
    <h3 class="text-2xl font-black text-on-surface mb-8">Add a Donation</h3>
    <form method="POST" action="/donate" enctype="multipart/form-data" class="flex flex-col gap-6">
      
      <div class="flex flex-col gap-3">
        <label for="productName" class="text-sm font-bold text-on-surface ml-1">Item Name</label>
        <input name="product[productName]" placeholder="e.g., Winter Jacket, T-Shirt, Jeans" type="text" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant" required />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label for="category" class="text-sm font-bold text-on-surface ml-1">Category</label>
          <select name="product[category]" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none appearance-none cursor-pointer" required>
            <option value="">Select a category</option>
            <option value="Clothing">Clothing</option>
            <option value="Footwear">Footwear</option>
            <option value="Accessories">Accessories</option>
            <option value="Home">Home & Decor</option>
            <option value="Electronics">Electronics</option>
            <option value="Books">Books</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label for="condition" class="text-sm font-bold text-on-surface ml-1">Condition</label>
          <select name="product[condition]" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none appearance-none cursor-pointer" required>
            <option value="">Select condition</option>
            <option value="New">New</option>
            <option value="Like New">Like New</option>
            <option value="Used">Used</option>
          </select>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="description" class="text-sm font-bold text-on-surface ml-1">Description</label>
        <textarea name="product[description]" placeholder="Describe your donation (size, material, any special details, etc.)" rows="4" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant resize-none" required></textarea>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold text-on-surface ml-1">Item Image</label>
        <input name="product[image]" type="file" accept="image/*" required class="w-full bg-surface py-4 px-6 rounded-2xl border-2 border-dashed border-outline-variant/50 hover:border-tertiary/50 focus:outline-none focus:ring-2 focus:ring-tertiary/50 transition-all file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-tertiary/10 file:text-tertiary hover:file:bg-tertiary/20 cursor-pointer" />
        <p class="text-xs text-on-surface-variant mt-2">Select an image from your device (JPEG, PNG, GIF, WebP - Max 5MB)</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label for="donor" class="text-sm font-bold text-on-surface ml-1">Your Name</label>
          <input name="product[seller]" placeholder="Your name" type="text" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant" required />
        </div>

        <div class="flex flex-col gap-2">
          <label for="contactNumber" class="text-sm font-bold text-on-surface ml-1">Contact Number</label>
          <input name="product[contactNumber]" placeholder="Your contact number" type="tel" pattern="[0-9]{10}" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant" required />
        </div>
      </div>

      <div class="pt-6 mt-4 border-t border-outline-variant/10">
        <button type="submit" class="w-full px-10 py-4 bg-[#198754] text-white rounded-xl font-bold shadow-lg shadow-[#198754]/20 hover:-translate-y-1 transition-transform flex items-center justify-center gap-2 text-lg">
          <i class="fa-solid fa-heart"></i> Make a Donation
        </button>
      </div>
    </form>
  </div>
</div>
