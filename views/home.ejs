<!-- How ReBorn Works Section -->
<section class="w-full min-h-fit py-0 px-6 lg:px-8 bg-gradient-to-b from-surface-container-low/30 to-surface-container-low/20">
  <div class="max-w-[1440px] mx-auto pt-8 md:pt-12 lg:pt-16">
    <div class="text-center mb-12 md:mb-20 lg:mb-24 relative">
      <span class="text-xs font-bold uppercase tracking-widest text-tertiary mb-2 block animate-fade-in-up">Simple & Seamless</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black editorial-display text-on-surface mb-4 md:mb-6 animate-fade-in-up delay-100">How It Works</h2>
      <p class="text-base md:text-lg lg:text-xl text-on-surface-variant max-w-2xl mx-auto animate-fade-in-up delay-200">From your closet to a new home in three easy steps.</p>
    </div>

    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">
    <!-- Connecting Line (Desktop) -->
    <div class="hidden md:block absolute top-1/2 left-0 w-full h-0.5 bg-gradient-to-r from-transparent via-outline-variant/30 to-transparent -translate-y-12 -z-10"></div>

    <!-- Step 1 -->
    <div class="group relative flex flex-col items-center text-center p-6 md:p-8">
      <div class="relative w-24 md:w-32 h-24 md:h-32 mb-6 md:mb-8 transition-transform duration-500 hover:scale-110">
        <div class="absolute inset-0 bg-secondary-container rounded-full blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <div class="relative w-full h-full bg-white rounded-full border border-outline-variant/10 shadow-xl flex items-center justify-center text-3xl md:text-4xl text-tertiary">
          <i class="fa-solid fa-camera"></i>
        </div>
        <div class="absolute -top-2 -right-2 w-8 md:w-10 h-8 md:h-10 bg-tertiary text-white rounded-full flex items-center justify-center font-bold text-sm md:text-lg border-4 border-white">1</div>
      </div>
      <h3 class="text-base md:text-lg font-bold text-on-surface mb-2 md:mb-3">Snap & List</h3>
      <p class="text-sm md:text-base text-on-surface-variant leading-relaxed max-w-xs">
        Take a photo, add details, and set your price. It takes less than 60 seconds.
      </p>
      
      <!-- Arrow Mobile -->
      <div class="md:hidden text-outline-variant/30 text-2xl md:text-3xl mt-6 md:mt-8 animate-bounce">
        <i class="fa-solid fa-arrow-down"></i>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="group relative flex flex-col items-center text-center p-6 md:p-8">
      <div class="relative w-24 md:w-32 h-24 md:h-32 mb-6 md:mb-8 transition-transform duration-500 hover:scale-110">
        <div class="absolute inset-0 bg-secondary-container rounded-full blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <div class="relative w-full h-full bg-white rounded-full border border-outline-variant/10 shadow-xl flex items-center justify-center text-3xl md:text-4xl text-tertiary">
          <i class="fa-solid fa-comments"></i>
        </div>
        <div class="absolute -top-2 -right-2 w-8 md:w-10 h-8 md:h-10 bg-tertiary text-white rounded-full flex items-center justify-center font-bold text-sm md:text-lg border-4 border-white">2</div>
      </div>
      <h3 class="text-base md:text-lg font-bold text-on-surface mb-2 md:mb-3">Connect</h3>
      <p class="text-sm md:text-base text-on-surface-variant leading-relaxed max-w-xs">
        Interested buyers will contact you directly to discuss details. No middleman needed.
      </p>

      <!-- Arrow Mobile -->
      <div class="md:hidden text-outline-variant/30 text-2xl md:text-3xl mt-6 md:mt-8 animate-bounce">
        <i class="fa-solid fa-arrow-down"></i>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="group relative flex flex-col items-center text-center p-6 md:p-8">
      <div class="relative w-24 md:w-32 h-24 md:h-32 mb-6 md:mb-8 transition-transform duration-500 hover:scale-110">
        <div class="absolute inset-0 bg-secondary-container rounded-full blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <div class="relative w-full h-full bg-white rounded-full border border-outline-variant/10 shadow-xl flex items-center justify-center text-3xl md:text-4xl text-tertiary">
          <i class="fa-solid fa-handshake-simple"></i>
        </div>
        <div class="absolute -top-2 -right-2 w-8 md:w-10 h-8 md:h-10 bg-tertiary text-white rounded-full flex items-center justify-center font-bold text-sm md:text-lg border-4 border-white">3</div>
      </div>
      <h3 class="text-base md:text-lg font-bold text-on-surface mb-2 md:mb-3">Exchange</h3>
      <p class="text-sm md:text-base text-on-surface-variant leading-relaxed max-w-xs">
        Meet up or arrange delivery to hand over the item and close the deal.
      </p>
    </div>
    </div>
  </div>
</section>

