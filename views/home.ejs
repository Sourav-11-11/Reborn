<% layout("/layouts/boilerplate") %>

<div class="reborn-hero">
  <div class="reborn-content d-flex flex-column justify-content-center align-items-end">
    <div class="reborn-title">ReBorn</div>
    <div class="reborn-caption">Give Your Stuff a Second Life
        <br> List your item now and let someone love <i class="fa-solid fa-heart"></i> it again. </div>
       
    <div class="reborn-buttons text-center mt-4">

      <div class="d-flex justify-content-center gap-4 flex-wrap mb-3">
        <a href="/products" class="btn btn-lg btn-outline-light px-4 rounded-pill">Browse Products</a>
        <a href="/products/new" class="btn btn-lg btn-outline-light px-4 rounded-pill shadow-sm">Sell a Product        </a>
      </div>

     </div>
  </div>
</div>

<section class="donate-section">
  <div class="container">
    <div class="row align-items-center">

      <div class="col-md-6 donate-text-area">
        <h2 class="donate-title">
          Your Unused Clothes Can Change Someone’s Life
        </h2>

        <p class="donate-text">
          That jacket sitting in your closet could mean warmth.
          Those clothes you haven’t worn in years could restore confidence.
        </p>

        <p class="donate-text">
          When you donate through ReBorn, you’re not just clearing space —
          you’re giving someone dignity, opportunity, and hope.
        </p>

        <div class="donate-points">
          <span>♻  Reduce waste</span>
          <span>❤️ Support people in need</span>
          <span>🌍 Make real impact</span>
        </div>

        <a href="/donate" class="btn btn-dark btn-lg mt-4">
          Start Donating Today
        </a>
      </div>

      <div class="col-md-6 donate-visual">
        <div class="donate-card">
          <h4>Small Action. Big Difference.</h4>
          <p>
            Every item you donate helps someone stay warm,
            feel confident, and move forward.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>