<% layout("/layouts/boilerplate") %>

<!-- Hero Section with Pattern Background -->
<div class="relative overflow-hidden bg-surface pb-24 pt-16">
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-tertiary/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-secondary-container/30 rounded-full blur-3xl"></div>

  <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
    <span class="inline-block py-1 px-3 rounded-full bg-tertiary/10 text-tertiary text-xs font-bold uppercase tracking-widest mb-6 animate-fade-in-up">
      Our Mission
    </span>
    <h1 class="text-4xl md:text-6xl font-black editorial-display tracking-tight text-on-surface mb-8 leading-[0.9] animate-fade-in-up delay-100">
      Redefining <span class="text-transparent bg-clip-text bg-gradient-to-r from-tertiary to-tertiary-dim">Ownership.</span><br>
      Reviving Style.
    </h1>
    <p class="text-xl text-on-surface-variant leading-relaxed max-w-2xl mx-auto animate-fade-in-up delay-200">
      ReBorn isn't just a marketplace. It's a movement against fast fashion, built on the belief that great style doesn't have an expiration date.
    </p>
  </div>
</div>

<!-- Main Content -->
<div class="max-w-[1200px] mx-auto px-6 pb-32 space-y-40">

  <!-- Value Props / Philosophy -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-10 py-8">
    <div class="group p-10 rounded-[2.5rem] bg-surface-container-low border border-outline-variant/10 hover:border-tertiary/20 hover:bg-white transition-all duration-300 transform hover:-translate-y-2 hover:shadow-xl hover:shadow-tertiary/5">
      <div class="w-16 h-16 rounded-2xl bg-tertiary/10 text-tertiary flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform duration-300">
        <i class="fa-solid fa-infinity"></i>
      </div>
      <h3 class="text-2xl font-bold text-on-surface mb-3 group-hover:text-tertiary transition-colors">Circular Life</h3>
      <p class="text-on-surface-variant leading-relaxed text-lg">
        We believe every item has multiple lives. By recirculating quality goods, we reduce waste and extend the story of the things we love.
      </p>
    </div>

    <div class="group p-8 rounded-[2.5rem] bg-surface-container-low border border-outline-variant/10 hover:border-orange-500/20 hover:bg-white transition-all duration-300 transform hover:-translate-y-2 hover:shadow-xl hover:shadow-orange-500/5">
      <div class="w-16 h-16 rounded-2xl bg-orange-100 text-orange-600 flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform duration-300">
        <i class="fa-solid fa-hand-holding-heart"></i>
      </div>
      <h3 class="text-2xl font-bold text-on-surface mb-3 group-hover:text-orange-600 transition-colors">Community First</h3>
      <p class="text-on-surface-variant leading-relaxed text-lg">
        This isn't a faceless platform. It's a community of mindful individuals who value quality, sustainability, and human connection.
      </p>
    </div>

    <div class="group p-8 rounded-[2.5rem] bg-surface-container-low border border-outline-variant/10 hover:border-green-500/20 hover:bg-white transition-all duration-300 transform hover:-translate-y-2 hover:shadow-xl hover:shadow-green-500/5">
      <div class="w-16 h-16 rounded-2xl bg-green-100 text-green-600 flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform duration-300">
        <i class="fa-solid fa-leaf"></i>
      </div>
      <h3 class="text-2xl font-bold text-on-surface mb-3 group-hover:text-green-600 transition-colors">Conscious Impact</h3>
      <p class="text-on-surface-variant leading-relaxed text-lg">
        Every transaction on ReBorn is a vote for a specialized, localized economy that prioritizes the planet alongside personal style.
      </p>
    </div>
  </section>

  <!-- The "Why" Section with Image/Visual -->
  <section class="relative bg-surface-container-low rounded-[3rem] p-10 md:p-16 overflow-hidden">
    <!-- Abstract graphical elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-tertiary/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center relative z-10">
      <div>
        <h2 class="text-3xl md:text-5xl font-black editorial-display mb-8 text-on-surface leading-none">Why ReBorn Matters</h2>
        <div class="space-y-6 text-lg text-on-surface-variant/90 leading-relaxed font-medium">
          <p>
            The fashion industry is one of the largest polluters in the world. By extending the life of just one garment by 9 months, we can reduce its carbon, waste, and water footprints by ~20-30%. ReBorn exists to make that choice easy, accessible, and stylish.
          </p>
        </div>
        
        <div class="mt-12 flex flex-wrap gap-8">
          <div class="flex flex-col">
            <span class="text-5xl font-black text-tertiary tracking-tighter">92M</span>
            <span class="text-xs uppercase tracking-wider font-bold text-on-surface-variant mt-2">Tons Waste/Year</span>
          </div>
          <div class="w-px h-16 bg-outline-variant/20 hidden md:block"></div>
          <div class="flex flex-col">
            <span class="text-5xl font-black text-tertiary tracking-tighter">20%</span>
            <span class="text-xs uppercase tracking-wider font-bold text-on-surface-variant mt-2">Global Wastewater</span>
          </div>
          <div class="w-px h-16 bg-outline-variant/20 hidden md:block"></div>
          <div class="flex flex-col">
            <span class="text-5xl font-black text-tertiary tracking-tighter">Zero</span>
            <span class="text-xs uppercase tracking-wider font-bold text-on-surface-variant mt-2">Waste Goal</span>
          </div>
        </div>
      </div>
      
      <!-- Visual representation -->
      <div class="relative h-full min-h-[500px] w-full bg-white rounded-[2.5rem] p-8 shadow-2xl shadow-tertiary/10 rotate-1 hover:rotate-0 transition-all duration-500 border border-outline-variant/5 overflow-hidden group">
        <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
            <i class="fa-solid fa-quote-right text-9xl"></i>
        </div>

        <div class="flex items-center gap-4 mb-8">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
        </div>
        
        <div class="space-y-6">
          <div class="h-4 bg-surface-container-low rounded-full w-3/4 animate-pulse"></div>
          <div class="h-4 bg-surface-container-low rounded-full w-1/2 animate-pulse delay-75"></div>
          <div class="h-4 bg-surface-container-low rounded-full w-5/6 animate-pulse delay-150"></div>
          
          <div class="grid grid-cols-2 gap-6 mt-12">
            <div class="aspect-square bg-tertiary/5 rounded-2xl flex flex-col items-center justify-center gap-3 text-tertiary/40 hover:bg-tertiary hover:text-white transition-all duration-300 cursor-default">
              <i class="fa-solid fa-shirt text-4xl"></i>
              <span class="text-xs font-bold uppercase tracking-widest">Wear</span>
            </div>
            <div class="aspect-square bg-tertiary/5 rounded-2xl flex flex-col items-center justify-center gap-3 text-tertiary/40 hover:bg-tertiary hover:text-white transition-all duration-300 cursor-default">
              <i class="fa-solid fa-recycle text-4xl"></i>
              <span class="text-xs font-bold uppercase tracking-widest">Share</span>
            </div>
            <div class="aspect-square bg-tertiary/5 rounded-2xl flex flex-col items-center justify-center gap-3 text-tertiary/40 hover:bg-tertiary hover:text-white transition-all duration-300 cursor-default">
              <i class="fa-solid fa-heart text-4xl"></i>
              <span class="text-xs font-bold uppercase tracking-widest">Care</span>
            </div>
            <div class="aspect-square bg-tertiary/5 rounded-2xl flex flex-col items-center justify-center gap-3 text-tertiary/40 hover:bg-tertiary hover:text-white transition-all duration-300 cursor-default">
              <i class="fa-solid fa-repeat text-4xl"></i>
              <span class="text-xs font-bold uppercase tracking-widest">Repeat</span>
            </div>
          </div>
        </div>
        
        <!-- Floating badge -->
        <div class="absolute bottom-8 right-8 bg-tertiary text-white p-6 rounded-2xl shadow-xl shadow-tertiary/30 transform rotate-3 group-hover:rotate-0 group-hover:scale-110 transition-all duration-300">
            <div class="text-center">
                <div class="text-[10px] font-bold uppercase tracking-widest opacity-80 mb-1">Established</div>
                <div class="text-4xl font-black">2026</div>
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="text-center py-10">
    <h2 class="text-3xl md:text-5xl font-black editorial-display text-on-surface mb-6">Join the Movement</h2>
    <p class="text-xl text-on-surface-variant mb-12 max-w-2xl mx-auto leading-relaxed">
      Whether you're looking for unique finds or clearing out your closet, you're part of the solution. Let's make fashion circular together.
    </p>
    <div class="flex flex-col sm:flex-row gap-6 justify-center">
      <a href="/products" class="group inline-flex items-center justify-center px-10 py-5 bg-tertiary text-white rounded-full font-bold text-lg hover:bg-tertiary-dim transition-all shadow-xl shadow-tertiary/25 hover:shadow-2xl hover:-translate-y-1">
        Browse Collection <i class="fa-solid fa-arrow-right ml-3 group-hover:translate-x-1 transition-transform"></i>
      </a>
      <a href="/donate" class="inline-flex items-center justify-center px-10 py-5 bg-white text-on-surface border border-outline-variant/20 rounded-full font-bold text-lg hover:bg-surface-container-low hover:border-outline-variant/40 transition-all shadow-sm hover:shadow-md">
        Make a Donation
      </a>
    </div>
  </section>

</div>