<% layout("/layouts/boilerplate") %>
<br>
<main class="main-content">

    <section class="about-hero "  >
        <div class="container">
            <h1>About ReBorn</h1>
            <p>Reuse. Relove. ReBorn.</p>
        </div>
    </section>

    <section class="about-section container">
        <div class="about-grid">
            <div class="about-text">
                <h2>Our Story</h2>
                <ul class="about-points">
                    <li>Built on one belief — everything deserves a second chance.</li>
                    <li>A response to fast fashion and careless consumption.</li>
                    <li>Created to turn unused items into meaningful opportunities.</li>
                    <li>Growing a community that values purpose over waste.</li>
                </ul>
            </div>

            <div class="about-text">
                <h2>Our Mission</h2>
                <ul class="about-points">
                    <li>Make sustainable shopping simple and accessible.</li>
                    <li>Connect conscious buyers with mindful sellers.</li>
                    <li>Encourage reuse over disposal.</li>
                    <li>Reduce waste through circular living.</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="values-section">
        <div class="container">
            <h2 class="section-title">What We Stand For</h2>

            <div class="values-grid">
                <div class="value-card">
                    <h4>Sustainability</h4>
                    <p>Encouraging reuse to reduce environmental impact and promote mindful consumption.</p>
                </div>

                <div class="value-card">
                    <h4>Community</h4>
                    <p>Building a trusted marketplace where buyers and sellers connect with purpose.</p>
                </div>

                <div class="value-card">
                    <h4>Transparency</h4>
                    <p>Honest listings, fair pricing, and clear communication at every step.</p>
                </div>

                <div class="value-card">
                    <h4>Social Impact</h4>
                    <p>Supporting communities through donations and empowering those in need with quality items.</p>
                </div>
            </div>
        </div>
    </section>

<!-- DONATION SECTION -->
<section class="donation-section py-5">
    <div class="container">
        <div class="row align-items-center g-5">

            <!-- Left Content -->
            <div class="col-lg-6">
                <h2 class="section-title mb-3">Make a Difference Through Donations</h2>
                <p class="text-muted mb-4">
                    Beyond buying and selling, ReBorn believes in giving back to the community.
                </p>

                <ul class="donation-list">
                    <li>Donate clothes and items you no longer need.</li>
                    <li>Support communities through our partnership with Woxsen University.</li>
                    <li>We coordinate pickup from your location.</li>
                    <li>Every donation creates meaningful impact.</li>
                </ul>

                <a href="/donate" class="btn btn-success btn-lg mt-3">
                    <i class="fa-solid fa-heart "></i> Start Donating
                </a>
            </div>

            <!-- Right Icon -->
            <div class="col-lg-6 text-center">
                <div class="donation-icon-wrapper">
                    <i class="fa-solid fa-hand-holding-heart"></i>
                </div>
            </div>

        </div>
    </div>
</section>


<!-- FINAL CTA SECTION -->
<section class="cta-green-section py-5">
    <div class="container text-center">
        <h2 class="section-title text-white mb-3">
            Ready to Give Something a Second Life?
        </h2>

        <p class="text-light mb-4">
            Join our growing community today.
        </p>

        <div class="d-flex justify-content-center flex-wrap gap-3">
            <a href="/products" class="btn btn-outline-light btn-lg">
                Explore Store
            </a>
            <a href="/products/new" class="btn btn-outline-light btn-lg">
                Start Selling
            </a>
            <a href="/donate" class="btn btn-outline-light btn-lg">
                Make a Donation &nbsp;<i class="fa-solid fa-heart "></i>
            </a>
        </div>
    </div>
</section>
</main>