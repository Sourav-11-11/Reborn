<% layout("/layouts/boilerplate") %>

<div class="max-w-[500px] mx-auto px-6 pt-4 md:pt-8 pb-24 min-h-[70vh]">
  <div class="text-center mb-10">
    <span class="inline-flex items-center gap-2 px-4 py-2 bg-tertiary-container/10 text-tertiary rounded-full mb-6">
      <span class="material-symbols-outlined text-[18px]">login</span>
      <span class="text-[10px] font-bold uppercase tracking-[0.05em]">Welcome Back</span>
    </span>
    <h3 class="text-4xl font-black editorial-display tracking-tight text-on-surface">Login to ReBorn</h3>
  </div>

  <div class="bg-surface-container-low p-10 md:p-12 rounded-[2rem] shadow-sm border border-outline-variant/10">
    <form action="/login" method="POST" class="needs-validation flex flex-col gap-6" novalidate>
      
      <div class="flex flex-col gap-2">
        <label for="username" class="text-sm font-bold text-on-surface ml-1">Username</label>
        <input name="username" id="username" type="text" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant text-base" required placeholder="Enter your username">
      </div>

      <div class="flex flex-col gap-2">
        <label for="password" class="text-sm font-bold text-on-surface ml-1">Password</label>
        <input name="password" id="password" type="password" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant text-base" required placeholder="••••••••">
      </div>

      <div class="mt-4">
        <button class="w-full px-8 py-4 bg-tertiary text-white rounded-xl font-bold shadow-lg shadow-tertiary/20 hover:-translate-y-1 transition-transform flex items-center justify-center gap-2">
          Login <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
        </button>
      </div>

    </form>

    <p class="text-center text-sm font-medium text-on-surface-variant mt-8">
      New around here? <a href="/signup" class="text-tertiary hover:underline">Create an account</a>
    </p>
  </div>
</div>