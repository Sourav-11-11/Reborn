<% layout("/layouts/boilerplate") %>

<div class="max-w-[700px] mx-auto px-6 pt-4 md:pt-8 pb-20 min-h-[70vh]">
  <div class="text-center mb-8">
    <span class="inline-flex items-center gap-2 px-4 py-2 bg-tertiary-container/10 text-tertiary rounded-full mb-4">
      <span class="material-symbols-outlined text-[18px]">person_add</span>
      <span class="text-[10px] font-bold uppercase tracking-[0.05em]">Join the Community</span>
    </span>
    <h3 class="text-4xl font-black editorial-display tracking-tight text-on-surface">Create an Account</h3>
  </div>

  <div class="bg-surface-container-low p-8 md:p-12 rounded-[2rem] shadow-sm border border-outline-variant/10">
    <form action="/signup" method="POST" class="needs-validation grid grid-cols-1 md:grid-cols-2 gap-6" novalidate>
      
      <div class="flex flex-col gap-2">
        <label for="username" class="text-sm font-bold text-on-surface ml-1">Username</label>
        <input name="username" id="username" type="text" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant text-base" required placeholder="Choose a username">
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="text-sm font-bold text-on-surface ml-1">Email</label>
        <input name="email" id="email" type="email" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant text-base" required placeholder="john@example.com">
      </div>

      <div class="flex flex-col gap-2 md:col-span-2">
        <label for="password" class="text-sm font-bold text-on-surface ml-1">Password</label>
        <input name="password" id="password" type="password" class="w-full bg-surface py-4 px-6 rounded-2xl border-none focus:ring-2 focus:ring-tertiary/50 outline-none transition-all placeholder:text-outline-variant text-base" required placeholder="••••••••">
      </div>

      <div class="md:col-span-2 mt-4">
        <button class="w-full px-8 py-4 bg-tertiary text-white rounded-xl font-bold shadow-lg shadow-tertiary/20 hover:-translate-y-1 transition-transform flex items-center justify-center gap-2">
          Sign Up <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
        </button>
      </div>

    </form>
    
    <p class="text-center text-sm font-medium text-on-surface-variant mt-8">
      Already have an account? <a href="/login" class="text-tertiary hover:underline">Log in now</a>
    </p>
  </div>
</div>