<% layout("/layouts/boilerplate") %>
<br>

<div class="alert alert-success alert-dismissible fade show" role="alert">
  <h4 class="alert-heading">
    <i class="fa-solid fa-check-circle"></i> Thank You So Much!
  </h4>
  <hr>
  <p class="mb-0">
    Your generous donation has been received! <i class="fa-solid fa-heart text-danger"></i><br><br>
    <strong>Your kindness truly makes a difference in someone's life.</strong><br><br>
    Every item donated helps those in need find quality clothing and essential items. 
    Together, we're creating a more compassionate community!
  </p>
</div>

<div class="row mt-5">
  <div class="col-md-8 offset-md-2">
    <h3 class="text-center mb-4 fw-bold">A Big Thank You! <i class="fa-solid fa-hands-holding-heart text-danger"></i></h3>
    
    <div class="card text-center">
      <div class="card-body p-4">
        <h5 class="card-title">Your Impact Matters!</h5>
        <p class="card-text">
          Thanks to donors like you, we're able to provide quality clothes and items to 
          people who need them most. Your contribution helps build a sustainable and 
          compassionate society.
        </p>
        <p class="text-muted">
          🙏 Thank you for being part of ReBorn's mission to give items a second life!
        </p>
      </div>
    </div>

    <div class="card mt-4 border-primary">
      <div class="card-body p-4">
        <h5 class="card-title">
          <i class="fa-solid fa-phone text-primary"></i> Next Steps
        </h5>
        <p class="card-text">
          Our dedicated team at <strong>Woxsen University</strong> will reach out to you soon 
          using the contact number you provided. We'll coordinate the pickup or delivery of your 
          donation and keep you updated on how your generous gift helps those in need.
        </p>
        <p class="text-muted mb-0">
          <small>Expect us to contact you within 24-48 hours. Thank you for your patience!</small>
        </p>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-md-6">
        <a href="/donate" class="btn btn-outline-success w-100">
          <i class="fa-solid fa-plus"></i> Donate More
        </a>
      </div>
      <div class="col-md-6">
        <a href="/" class="btn btn-outline-secondary w-100">
          <i class="fa-solid fa-home"></i> Back to Home
        </a>
      </div>
    </div>
  </div>
</div>
<br><br><br><br><br>
