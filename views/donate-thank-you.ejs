<% layout("/layouts/boilerplate") %>

<!-- Confetti Canvas -->
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

<div class="relative min-h-[85vh] flex items-center justify-center p-6 overflow-hidden">
  
  <!-- Decorative background elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10">
    <!-- Soft gradient background -->
    <div class="absolute inset-0 bg-gradient-to-b from-surface-container-low to-surface"></div>
    
    <!-- Floating icons -->
    <div class="absolute top-10 left-10 text-tertiary/10 text-6xl animate-bounce duration-[3000ms]"><i class="fa-solid fa-star"></i></div>
    <div class="absolute bottom-20 right-20 text-tertiary/10 text-8xl animate-pulse"><i class="fa-solid fa-heart"></i></div>
    <div class="absolute top-1/2 left-20 text-secondary-container/50 text-4xl animate-bounce duration-[2000ms]"><i class="fa-solid fa-gift"></i></div>
    <div class="absolute top-20 right-1/3 text-tertiary/5 text-5xl animate-bounce duration-[4000ms]"><i class="fa-solid fa-hand-holding-heart"></i></div>
  </div>

  <div class="max-w-3xl w-full relative z-10 text-center">
    
    <!-- Main Celebration Card -->
    <div class="bg-surface/80 backdrop-blur-xl border border-white/50 p-10 md:p-14 rounded-[3rem] shadow-2xl shadow-tertiary/10 transform transition-all hover:shadow-tertiary/20">
      
      <!-- Animated Icon -->
      <div class="mb-8 relative inline-block">
        <div class="absolute inset-0 bg-tertiary/20 rounded-full blur-xl animate-pulse"></div>
        <div class="relative bg-gradient-to-br from-[#198754] to-[#146c43] text-white w-24 h-24 rounded-full flex items-center justify-center text-5xl shadow-lg mx-auto transform hover:scale-110 transition-transform duration-300">
          <i class="fa-solid fa-check"></i>
        </div>
      </div>

      <!-- Heading -->
      <h1 class="text-4xl md:text-6xl font-black editorial-display text-transparent bg-clip-text bg-gradient-to-r from-tertiary to-tertiary-dim mb-6 tracking-tight animate-fade-in-up">
        You're Amazing!
      </h1>

      <!-- Message -->
      <div class="space-y-6">
        <p class="text-xl md:text-2xl text-on-surface-variant leading-relaxed font-medium">
          Your generous donation has been received. <br>
          <span class="text-tertiary font-bold relative inline-block">
            You just made the world brighter!
            <svg class="absolute -bottom-2 w-full h-3 text-tertiary/20" viewBox="0 0 100 10" preserveAspectRatio="none">
              <path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="3" fill="none" />
            </svg>
          </span> ✨
        </p>

        <!-- Impact Box -->
        <div class="bg-surface-container-low/50 rounded-2xl p-8 border border-dashed border-tertiary/30 mx-auto max-w-xl hover:bg-surface-container-low transition-colors duration-300">
          <div class="flex flex-col items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-tertiary/10 flex items-center justify-center text-tertiary text-xl">
              <i class="fa-solid fa-hands-holding-circle"></i>
            </div>
            <div>
              <p class="text-on-surface font-bold text-lg mb-2">
                Your impact starts now
              </p>
              <p class="text-sm text-on-surface-variant leading-relaxed">
                Our team from <strong>Woxsen University</strong> will contact you within 24-48 hours to arrange pickup. Get ready to make a difference!
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12">
        <a href="/donate" class="group relative px-8 py-4 bg-tertiary text-white rounded-2xl font-bold text-lg shadow-xl shadow-tertiary/30 hover:shadow-2xl hover:-translate-y-1 transition-all overflow-hidden flex items-center justify-center gap-3">
          <span class="relative z-10 flex items-center gap-2">
            <i class="fa-solid fa-plus-circle group-hover:rotate-90 transition-transform duration-300"></i> 
            Donate Again
          </span>
          <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
        </a>
        
        <a href="/" class="px-8 py-4 bg-surface-container-highest text-on-surface rounded-2xl font-bold text-lg hover:bg-surface-container-high hover:-translate-y-1 transition-all flex items-center justify-center gap-2">
          <i class="fa-solid fa-home text-on-surface-variant"></i>
          Back Home
        </a>
      </div>
    
      <p class="mt-10 text-on-surface-variant/60 text-sm font-medium italic">
        "We make a living by what we get, but we make a life by what we give."
      </p>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Initial burst
    confetti({
      particleCount: 150,
      spread: 100,
      origin: { y: 0.6 },
      colors: ['#005dbc', '#198754', '#ffc107', '#dc3545']
    });

    // 2. School pride / continuous celebration
    var end = Date.now() + 3000;

    (function frame() {
      confetti({
        particleCount: 3,
        angle: 60,
        spread: 55,
        origin: { x: 0 },
        colors: ['#005dbc', '#0051a6']
      });
      confetti({
        particleCount: 3,
        angle: 120,
        spread: 55,
        origin: { x: 1 },
        colors: ['#005dbc', '#0051a6']
      });

      if (Date.now() < end) {
        requestAnimationFrame(frame);
      }
    }());
    
    // 3. Random bursts for "pop" effect
    setTimeout(() => {
        confetti({ particleCount: 50, spread: 60, origin: { x: 0.2, y: 0.5 } });
    }, 1000);
    
    setTimeout(() => {
        confetti({ particleCount: 50, spread: 60, origin: { x: 0.8, y: 0.5 } });
    }, 2000);
  });
</script>
