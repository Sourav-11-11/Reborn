<% layout("/layouts/boilerplate") %>

<div class="max-w-[1200px] mx-auto px-6 pt-0 pb-12 lg:px-8 min-h-[70vh]">
  
  <div class="flex flex-col items-center justify-center text-center py-24">
    
    <!-- Error Icon -->
    <div class="mb-8">
      <span class="material-symbols-outlined text-9xl text-error">error</span>
    </div>
    
    <!-- Error Message -->
    <h1 class="text-5xl md:text-6xl font-black text-on-surface mb-4 editorial-display">
      Oops! Something Went Wrong
    </h1>
    
    <!-- Error Details -->
    <p class="text-xl text-on-surface-variant mb-8 max-w-2xl leading-relaxed text-balance">
      <%= message %>
    </p>
    
    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="px-8 py-4 bg-tertiary text-white rounded-xl font-bold shadow-lg shadow-tertiary/20 hover:-translate-y-1 transition-transform text-center">
        Back to Home
      </a>
      <a href="/products" class="px-8 py-4 bg-surface-container-highest text-on-surface rounded-xl font-bold hover:-translate-y-1 transition-transform text-center">
        Browse Products
      </a>
    </div>
    
    <!-- Help Text -->
    <p class="text-sm text-on-surface-variant mt-12 max-w-md">
      If you continue to experience issues, please reach out to us via the contact information in the footer.
    </p>
    
  </div>
  
</div>
