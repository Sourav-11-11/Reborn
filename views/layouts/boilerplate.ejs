<!DOCTYPE html>
<html lang="en" class="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>ReBorn - Curating the Secondary Market</title>
        
        <!-- Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
        
        <!-- Tailwind CDN -->
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        
        <!-- Tailwind Configuration -->
        <script id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                colors: {
                  "tertiary": "#005dbc",
                  "tertiary-dim": "#0051a6",
                  "surface-container-low": "#f2f4f6",
                  "primary": "#5f5e5e",
                  "secondary-container": "#e3e2e7",
                  "outline-variant": "#acb3b8",
                  "primary-dim": "#535252",
                  "background": "#f9f9fb",
                  "on-surface": "#2d3338",
                  "surface-dim": "#d3dbe2",
                  "tertiary-container": "#378afd",
                  "on-surface-variant": "#596065",
                  "on-primary": "#faf7f6",
                  "surface-container": "#ebeef2",
                  "surface-variant": "#dde3e9",
                  "surface": "#f9f9fb",
                  "surface-bright": "#f9f9fb",
                  "surface-container-highest": "#dde3e9",
                  "surface-container-lowest": "#ffffff"
                },
                keyframes: {
                  fadeInUp: {
                    '0%': { opacity: '0', transform: 'translateY(10px)' },
                    '100%': { opacity: '1', transform: 'translateY(0)' },
                  }
                },
                animation: {
                  'fade-in-up': 'fadeInUp 0.8s ease-out forwards',
                },
                fontFamily: {
                  "headline": ["Inter"],
                  "body": ["Inter"],
                  "label": ["Inter"]
                },
                borderRadius: {"DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"},
              },
            },
          }
        </script>
        <style>
          .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
          body { font-family: 'Inter', sans-serif; background-color: #f9f9fb; color: #2d3338; min-height: 100vh; }
          .editorial-display { letter-spacing: -0.04em; line-height: 1.1; }
          .text-balance { text-wrap: balance; }
        </style>
        
        <link rel="stylesheet" href="/css/style.css">
    </head>
    <body class="bg-surface text-on-surface selection:bg-tertiary/20 flex flex-col min-h-screen">
        <%- include("../includes/navbar") %>
        
        <%- include("../includes/flash") %>

        <div class="flex-grow w-full pt-6">
            <%- body %>
        </div>

        <%- include("../includes/footer") %>
        
        <script src="/js/script.js"></script>
    </body>
</html>